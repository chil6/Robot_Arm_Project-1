#include <Wire.h>
#include <Adafruit_SSD1306.h>
#include <DHT.h>

Adafruit_SSD1306 display(128, 64, &Wire, -1);

// -------- Pins --------
const int btn1 = 33;
const int btn2 = 32;

const int potPin = 14;
const int ledPin = 12;

const int trigPin = 5;
const int echoPin = 18;

// -------- DHT --------
#define DHTPIN 4
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

// -------- Mode --------
int mode = 0;

// -------- Button states --------
bool lastB1 = 0;
bool lastB2 = 0;

long duration;
float distance;

void setup() {
  Serial.begin(115200);

  pinMode(btn1, INPUT_PULLDOWN);
  pinMode(btn2, INPUT_PULLDOWN);

  pinMode(ledPin, OUTPUT);
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  Wire.begin(21, 22);

  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();

  dht.begin();
}

void loop() {

  bool b1 = digitalRead(btn1);
  bool b2 = digitalRead(btn2);

  // -------- detect NEW press (edge) --------
  if (b1 && !lastB1) {
    mode = 1;
    Serial.println("Mode 1: DHT");
  }

  if (b2 && !lastB2) {
    mode = 2;
    Serial.println("Mode 2: Pot");
  }

  if (b1 && b2 && (!lastB1 || !lastB2)) {
    mode = 3;
    Serial.println("Mode 3: Distance");
  }

  lastB1 = b1;
  lastB2 = b2;

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);

  // ================= MODE 1 =================
  if (mode == 1) {
    float t = dht.readTemperature();
    float h = dht.readHumidity();

    display.setCursor(0, 10);
    display.print("TEMP / HUM");

    display.setCursor(0, 30);
    display.print("T: ");
    display.print(t);

    display.setCursor(0, 45);
    display.print("H: ");
    display.print(h);
  }

  // ================= MODE 2 =================
  else if (mode == 2) {
    int pot = analogRead(potPin);
    int pwm = map(pot, 0, 4095, 0, 255);

    analogWrite(ledPin, pwm);

    display.setCursor(0, 10);
    display.print("POT MODE");

    display.setCursor(0, 30);
    display.print("LED: ");
    display.print(pwm);
  }

  // ================= MODE 3 =================
  else if (mode == 3) {
    digitalWrite(trigPin, LOW);
    delayMicroseconds(2);
    digitalWrite(trigPin, HIGH);
    delayMicroseconds(10);
    digitalWrite(trigPin, LOW);

    duration = pulseIn(echoPin, HIGH, 30000);

    if (duration == 0) distance = -1;
    else distance = duration * 0.0343 / 2;

    display.setCursor(0, 10);
    display.print("DIST MODE");

    display.setCursor(0, 30);
    display.print(distance);
    display.print(" cm");
  }

  display.display();
  delay(100);
}

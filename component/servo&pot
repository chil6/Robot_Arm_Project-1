#include <ESP32Servo.h>

Servo myservo;

int potPin = 34;
int servoPin = 13;
int potValue = 0;
int angle = 0;

void setup() {
  Serial.begin(115200);
  myservo.attach(servoPin);
}

void loop() {
  potValue = analogRead(potPin);
  angle = map(potValue, 0, 4095, 0, 180);
  myservo.write(angle);

  Serial.print("Pot: ");
  Serial.print(potValue);
  Serial.print("  Angle: ");
  Serial.println(angle);

  delay(15);
}
